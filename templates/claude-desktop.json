{
  "mcpServers": {
    "skills-whm-pro": {
      "type": "streamable-http",
      "url": "http://mcp.example.com:3200/mcp",
      "headers": {
        "x-api-key": "YOUR_WHM_MCP_API_KEY_HERE"
      }
    }
  }
}

// ⚙️  CONFIGURAÇÃO - Valores do .env do servidor
//
// 1. x-api-key: Copie WHM_MCP_API_KEY do arquivo .env
//    Exemplo: YOUR_WHM_MCP_API_KEY
//
// 2. Para operações destrutivas (delete, suspend, restart):
//    - confirmationToken: Use MCP_SAFETY_TOKEN do .env
//    - reason: Justificativa obrigatória (min 10 chars)
//
// 📌 Exemplo de operação com Safety Guard:
// delete_domain({
//   domain: "exemplo.com",
//   username: "user123",
//   type: "addon",
//   confirmationToken: "SEU_MCP_SAFETY_TOKEN_AQUI",
//   reason: "Solicitação cliente ticket #1234"
// })
